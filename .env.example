# ── AI Studio integration ───────────────────────────────────────────────────
# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# ── AeroGrid server ─────────────────────────────────────────────────────────
# Port the Node.js backend listens on (default: 4000)
SERVER_PORT=4000

# WebSocket URL the browser connects to.
# Leave blank in development — Vite proxy forwards /ws automatically.
# In production set this to your deployed server, e.g.:
#   VITE_SERVER_WS_URL=wss://api.yourapp.com/ws
VITE_SERVER_WS_URL=

# ── Production DB (optional — SQLite is used by default) ───────────────────
# Uncomment after running: docker compose up -d
# DATABASE_URL=postgresql://aerogrid:aerogrid_password@localhost:5432/aerogrid
# REDIS_URL=redis://localhost:6379
